# ============================================
# JWT & SEGURIDAD
# ============================================
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_minimo_64_caracteres!!!
JWT_REFRESH_SECRET=otro_secreto_largo_diferente_para_refresh_tokens_64_chars!!!
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
BCRYPT_ROUNDS=12
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# ============================================
# SERVIDOR
# ============================================
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# Para evitar que Render se duerma (auto-ping cada 14 min)
RENDER=true
SELF_URL=https://rifas-san-backend.onrender.com

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ============================================
# PROVEEDORES DE PAGO
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

MERCADOPAGO_ACCESS_TOKEN=TEST-...
MERCADOPAGO_PUBLIC_KEY=TEST-...
MERCADOPAGO_WEBHOOK_SECRET=...

PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_WEBHOOK_ID=...

# ============================================
# EMAIL / NOTIFICACIONES
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@tusorteos.com
SMTP_PASSWORD=...
SMTP_FROM="Tu Sorteos <noreply@tusorteos.com>"

# ============================================
# BACKUPS
# ============================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=rifas-san-backups
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ============================================
# MONITOREO
# ============================================
SENTRY_DSN=...
LOG_LEVEL=info
